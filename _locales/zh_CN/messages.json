{
  "appName": { "message": "AI 对话批量删除器" },
  "appDesc": { "message": "在 ChatGPT 与 Gemini 网页界面批量删除对话，支持预览与勾选。" },
  "scan": { "message": "扫描" },
  "selectAll": { "message": "全选" },
  "deleteSelected": { "message": "删除所选项目" },
  "deleteSelectedCount": {
    "message": "删除所选项目（$count$）",
    "placeholders": { "count": { "content": "$1" } }
  },
  "close": { "message": "关闭" },
  "noScanned": { "message": "尚未扫描对话。" },
  "foundCount": {
    "message": "找到 $count$ 条对话。",
    "placeholders": { "count": { "content": "$1" } }
  },
  "deleting": {
    "message": "正在删除 $count$ 条所选对话…",
    "placeholders": { "count": { "content": "$1" } }
  },
  "rescanned": { "message": "已重新扫描。" },
  "done": {
    "message": "完成。已删除＝$deleted$ 失败＝$failed$ 跳过＝$skipped$",
    "placeholders": { "deleted": { "content": "$1" }, "failed": { "content": "$2" }, "skipped": { "content": "$3" } }
  },
  "logLine": {
    "message": "[$index$/$total$] $status$：$title$",
    "placeholders": { "index": { "content": "$1" }, "total": { "content": "$2" }, "status": { "content": "$3" }, "title": { "content": "$4" } }
  },
  "statusDeleted": { "message": "已删除" },
  "statusFailed": { "message": "失败" },
  "statusSkipped": { "message": "跳过" }
}
