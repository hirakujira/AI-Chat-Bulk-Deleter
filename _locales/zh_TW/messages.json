{
  "appName": { "message": "AI 對話批次刪除器" },
  "appDesc": { "message": "在 ChatGPT、Gemini 與 Claude 網頁介面批次刪除對話，支援預覽與勾選。" },
  "scan": { "message": "掃描" },
  "selectAll": { "message": "全選" },
  "deleteSelected": { "message": "刪除選取項目" },
  "deleteSelectedCount": {
    "message": "刪除選取項目（$count$）",
    "placeholders": { "count": { "content": "$1" } }
  },
  "close": { "message": "關閉" },
  "noScanned": { "message": "尚未掃描對話。" },
  "foundCount": {
    "message": "找到 $count$ 筆對話。",
    "placeholders": { "count": { "content": "$1" } }
  },
  "deleting": {
    "message": "正在刪除 $count$ 筆選取的對話…",
    "placeholders": { "count": { "content": "$1" } }
  },
  "rescanned": { "message": "已重新掃描。" },
  "done": {
    "message": "完成。已刪除＝$deleted$ 失敗＝$failed$ 略過＝$skipped$",
    "placeholders": { "deleted": { "content": "$1" }, "failed": { "content": "$2" }, "skipped": { "content": "$3" } }
  },
  "logLine": {
    "message": "[$index$/$total$] $status$：$title$",
    "placeholders": { "index": { "content": "$1" }, "total": { "content": "$2" }, "status": { "content": "$3" }, "title": { "content": "$4" } }
  },
  "statusDeleted": { "message": "已刪除" },
  "statusFailed": { "message": "失敗" },
  "statusSkipped": { "message": "略過" }
}
