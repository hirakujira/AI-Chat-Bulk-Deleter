{
  "appName": { "message": "AI チャット一括削除ツール" },
  "appDesc": { "message": "ChatGPT、Gemini、Claude のウェブ画面で会話を一括削除します。プレビューと選択に対応。" },
  "scan": { "message": "スキャン" },
  "selectAll": { "message": "すべて選択" },
  "deleteSelected": { "message": "選択した項目を削除" },
  "deleteSelectedCount": {
    "message": "選択した項目を削除（$count$）",
    "placeholders": { "count": { "content": "$1" } }
  },
  "close": { "message": "閉じる" },
  "noScanned": { "message": "会話はまだスキャンされていません。" },
  "foundCount": {
    "message": "$count$ 件の会話が見つかりました。",
    "placeholders": { "count": { "content": "$1" } }
  },
  "deleting": {
    "message": "選択した $count$ 件の会話を削除しています…",
    "placeholders": { "count": { "content": "$1" } }
  },
  "rescanned": { "message": "再スキャンしました。" },
  "done": {
    "message": "完了。削除＝$deleted$ 失敗＝$failed$ スキップ＝$skipped$",
    "placeholders": { "deleted": { "content": "$1" }, "failed": { "content": "$2" }, "skipped": { "content": "$3" } }
  },
  "logLine": {
    "message": "[$index$/$total$] $status$：$title$",
    "placeholders": { "index": { "content": "$1" }, "total": { "content": "$2" }, "status": { "content": "$3" }, "title": { "content": "$4" } }
  },
  "statusDeleted": { "message": "削除済み" },
  "statusFailed": { "message": "失敗" },
  "statusSkipped": { "message": "スキップ" }
}
